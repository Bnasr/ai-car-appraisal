<!DOCTYPE html>
<html>
<head>
  <title>AI Car Appraisal</title>
</head>

<body>

<h2>AI Car Appraisal</h2>

<div id="chat"></div>

<input id="input" placeholder="Type here..." />
<button onclick="send()">Send</button>

<script>
let step = 0;

function send() {
  let input = document.getElementById("input").value;
  let chat = document.getElementById("chat");

  chat.innerHTML += "<div><b>You:</b> " + input + "</div>";

  let response = "";

  if (step === 0) {
    response = "What’s the year, make, and model?";
    step = 1;
  } 
  else if (step === 1) {
    response = "How many miles?";
    step = 2;
  } 
  else if (step === 2) {
    response = "Condition? (clean / average / needs work)";
    step = 3;
  } 
  else if (step === 3) {
    response = "Any mechanical issues? (yes/no)";
    step = 4;
  } 
  else if (step === 4) {
    response = "Estimated value: $20,000 - $24,000";
    step = 5;
  } 
  else if (step === 5) {
    response = "Want to see real offers? (yes/no)";
    step = 6;
  } 
  else if (step === 6) {
    if (input.toLowerCase() === "yes") {
      response = "What’s your name?";
      step = 7;
    } else {
      response = "No problem!";
    }
  } 
  else if (step === 7) {
    response = "Phone number?";
    step = 8;
  } 
  else if (step === 8) {
    response = "Email?";
    step = 9;
  } 
  else if (step === 9) {
    response = "Thanks! A dealer will contact you.";
  }

  chat.innerHTML += "<div><b>AI:</b> " + response + "</div>";

  document.getElementById("input").value = "";
}
</script>

</body>
</html>
